# mesh-mqtt-pg-collector environment variables
# Copy to .env and adjust values as needed.
# These override any settings in config.yaml.

# --- MQTT ---
# COLLECTOR_MQTT_BROKER=127.0.0.1
# COLLECTOR_MQTT_PORT=1883
# COLLECTOR_MQTT_USERNAME=
# COLLECTOR_MQTT_PASSWORD=
# COLLECTOR_MQTT_TOPIC_PREFIX=msh
# COLLECTOR_MQTT_TOPIC_SUFFIX=/+/+/+/#
# COLLECTOR_MQTT_CLIENT_ID=mesh-mqtt-pg-collector

# --- PostgreSQL ---
# COLLECTOR_POSTGRES_HOST=localhost
# COLLECTOR_POSTGRES_PORT=5432
# COLLECTOR_POSTGRES_USER=meshtastic
# COLLECTOR_POSTGRES_PASSWORD=meshtastic
# COLLECTOR_POSTGRES_DBNAME=meshtastic

# --- Encryption ---
# COLLECTOR_DEFAULT_KEY=1PG7OiApB1nwvP+rz05pAQ==

# --- Logging ---
# COLLECTOR_LOG_LEVEL=INFO
